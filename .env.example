BACKEND_PORT=5555

# Supabase Postgres connection URL
DATABASE_URL=postgres://postgres:[PASSWORD]@[HOST]:5432/postgres

# Auth and mail settings used by backend config
PEPPER=replace-me
ACS_TKN_SCT=replace-me
RFS_TKN_SCT=replace-me
ACS_TKN_EXP=15m
RFS_TKN_EXP=30d

RESEND_API_KEY=replace-me
GOOGLE_CLIENT_ID=replace-me

# Shared storage and webhook settings
AZURE_STORAGE_CONNECTION_STRING=replace-me
AZURE_STORAGE_CONTAINER_NAME=event
BLOB_PATH_PREFIX=dev
WEBHOOK_SECRET=replace-me